---
import "../styles/global.css";

const navLinks = [
  { label: "Wellness", href: "#" },
  { label: "Medical", href: "#" },
  { label: "Aesthetics", href: "#" },
  { label: "Body Shaping", href: "#" },
  { label: "About", href: "#" },
];

const heroBenefits = [
  "FEEL BETTER, HEAL FASTER",
  "BUILD MUSCLE, LOSE FAT",
  "RELIEVE PAIN, MOVE FREELY",
  "SIGNIFICANT WEIGHT LOSS",
  "AMAZING SKIN, LESS DOWNTIME",
];

const brandLogos = [
  { src: "/images/brand-purewave.png", alt: "Pure Wave" },
  { src: "/images/brand-aspenlaser.png", alt: "Aspen Laser" },
  { src: "/images/brand-btl.png", alt: "BTL Aesthetics" },
  { src: "/images/brand-cryorelief.png", alt: "Cryo Relief" },
  { src: "/images/brand-davincimedical.png", alt: "Davinci Medical" },
  { src: "/images/brand-emsculptneo.png", alt: "Emsculpt Neo" },
  { src: "/images/brand-hrt.png", alt: "HRT" },
  { src: "/images/brand-hypermax.png", alt: "HyperMax Oxygen" },
  { src: "/images/brand-normatec.png", alt: "Normatec" },
  { src: "/images/brand-theralight360.png", alt: "TheraLight360" },
  { src: "/images/brand-pulse-pemf.webp", alt: "Pulse PEMF" },
  { src: "/images/brand-superhuman.jpg", alt: "Superhuman Protocol" },
];

const treatments = [
  { category: "WELLNESS", title: "Red Light Therapy", img: "/images/card-red-light.jpg", href: "#" },
  { category: "WELLNESS", title: "Aspen Laser", img: "/images/card-aspen-laser.jpg", href: "#" },
  { category: "WELLNESS", title: "Superhuman Protocol", img: "/images/card-superhuman-51.jpg", href: "#" },
  { category: "MEDICAL", title: "Weight Loss", img: "/images/card-weight-loss.webp", href: "#" },
  { category: "AESTHETICS", title: "Helix Laser", img: "/images/card-helix-laser.webp", href: "#" },
  { category: "BODY SHAPING", title: "Emsculpt Neo", img: "/images/card-emsculpt-neo.jpg", href: "#" },
];

const peakFeatures = [
  { title: "SCIENCE-BACKED WELLNESS", desc: "Advanced therapies for real health improvements." },
  { title: "PERSONALIZED CARE PLANS", desc: "Treatments tailored to your unique goals." },
  { title: "EXPERIENCED HOLISTIC LEADERS", desc: "Guiding you with decades of expertise." },
  { title: "CUTTING-EDGE RESULTS", desc: "Latest tech for visible, lasting changes." },
  { title: "YOUR VITALITY ELEVATED", desc: "Feel better, look better, live fully." },
];

const beforeAfter = [
  { img: "/images/ba-emtone-arms.webp", label: "EMTONE" },
  { img: "/images/ba-emsculpt-weightloss-man.webp", label: "EMSCULPT + Weight Loss Shots" },
  { img: "/images/ba-emsculpt-abs.webp", label: "EMSCULPT" },
  { img: "/images/ba-semaglutide-weightloss.jpg", label: "Weight Loss" },
  { img: "/images/ba-helix-stretchmarks.webp", label: "Helix Laser" },
  { img: "/images/ba-emsculpt-bodyshaping.webp", label: "EMSCULPT" },
  { img: "/images/ba-helix-face.webp", label: "Helix Laser" },
  { img: "/images/ba-emtone-butt.webp", label: "EMTONE" },
];

const financingBullets = [
  "Fast & Easy",
  "Budget Friendly",
  "0% Interest Available",
  "No Hard Credit Checks",
  "Flexible Payments",
];

const testimonials = [
  { author: "IRENE", quote: "Pani performed the helix fusion laser resurfacing on my face and I am thrilled with the results. Less than a week down time! All my brown spots have disappeared as well as my small fine lines around my eyes. I would highly recommend this laser treatment at the Peak Wellness Spa!" },
  { author: "MARY", quote: "I highly recommend Peak Wellness Spa to anyone looking for a professional, relaxing, and effective laser treatment experience with Pani, I couldn't be more impressed! The results have been amazing as my skin feels smoother, rejuvenated, and more vibrant than ever." },
  { author: "MENNEN", quote: "Absolutely fantastic place to begin to heal your body and mind. Love the Aspen Laser to treat my mother's sciatic nerve pain while I love the weight loss program. We both experienced positive results." },
  { author: "JIM", quote: "I had bad chronic pain in my shoulder. Edye and Pani came up with a game plan. Between the Aspen laser, red light therapy and the pemf bed, I've had very little to no pain. I'm thankful for Edye's expertise and knowledge. I'm now living pain free. Thank you" },
  { author: "SUE", quote: "The Peak is the place to go for your wellness treatments! The staff is knowledgeable, helpful, and generous with their time. They give extra attention to your specific needs and tailor your care individually! I highly recommend you visit The Peak!" },
  { author: "WILLIAM", quote: "My girlfriend asked me for months to try the services, but I didn't take her up on it until my elbow was badly hurting - it was the best thing I could've done. I did Cryo, PEMF, and red light. My elbow feels so much better. Also, shout out to Edye - amazing owner!" },
  { author: "EDEN", quote: "Had an Emsculpt Neo treatment. What a cool device. I've had really good results after my 4 treatments. I can definitely see more definition. Catherine was amazing, very knowledgeable and helpful through the whole experience." },
];

const featureIcons = [
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><path d='M12 21s-7-4.35-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.65-7 10-7 10z'/></svg>`,
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 2'/></svg>`,
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><circle cx='12' cy='7' r='4'/><path d='M4 21c0-4 4-6 8-6s8 2 8 6'/></svg>`,
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><path d='M12 2l2.39 4.84 5.34.78-3.86 3.77.91 5.32L12 14.27 7.22 16.71l.91-5.32L4.27 7.62l5.34-.78z'/></svg>`,
  `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'><path d='M3 12h4l3-9 4 18 3-9h4'/></svg>`,
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Peak Wellness Spa | Scottsdale, AZ — Clone</title>
    <meta name="description" content="Wellness center in Scottsdale, AZ — unlock your peak potential." />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link rel="stylesheet" href="https://fonts.bunny.net/css?family=figtree:300,400,600,700|josefin-sans:300,400,600,700,800,900&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  </head>
  <body class="bg-white text-[#5E5E5E]">

    {/* ============================================
        TOP INFO STRIP
        ============================================ */}
    <div class="bg-[#F6F2E9] text-[#121B24] text-[12px]">
      <div class="max-w-[1440px] mx-auto px-6 py-2 flex flex-col md:flex-row items-center justify-between gap-2">
        <div class="flex flex-wrap items-center gap-x-6 gap-y-1 font-[Figtree] tracking-[0.05em]">
          <span>8912 E Pinnacle Peak Rd Suite F-4, Scottsdale, AZ 85255</span>
          <span class="hidden md:inline opacity-40">|</span>
          <span>Mon-Fri 9-4, Sat 9-2, Sun Closed</span>
        </div>
        <div class="flex items-center gap-4">
          <a href="tel:6023131488" class="hover:text-[#D7A67B] transition-colors">(602) 313-1488</a>
          <div class="flex items-center gap-2">
            <a href="#" aria-label="Facebook" class="w-7 h-7 border border-[#121B24] flex items-center justify-center hover:bg-[#1B2A54] hover:border-[#1B2A54] hover:text-white transition-all">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10V7c0-1 1-2 2-2h2V2h-3a5 5 0 0 0-5 5v3H7v3h2v9h4v-9h3l1-3z"/></svg>
            </a>
            <a href="#" aria-label="Instagram" class="w-7 h-7 border border-[#121B24] flex items-center justify-center hover:bg-[#1B2A54] hover:border-[#1B2A54] hover:text-white transition-all">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* ============================================
        NAVIGATION (not sticky)
        ============================================ */}
    <nav class="bg-white border-b border-[#E5E0D6] relative z-40">
      <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between gap-6">
        <a href="/" class="flex items-center">
          <img src="/images/logo-main.png" alt="The Peak Wellness Spa" class="h-[64px] w-auto" />
        </a>
        <ul class="hidden lg:flex items-center gap-8">
          {navLinks.map((l) => (
            <li><a href={l.href} class="nav-link">{l.label}</a></li>
          ))}
        </ul>
        <div class="flex items-center gap-4">
          <a href="tel:6023131488" class="hidden md:inline nav-link">(602) 313-1488</a>
          <a href="#" class="hidden sm:inline-flex btn btn-outline-dark">Schedule</a>
          <button id="hamburger" class="lg:hidden flex flex-col gap-[5px] p-2" aria-label="Menu">
            <span class="block w-6 h-[2px] bg-[#121B24] transition-all duration-300"></span>
            <span class="block w-6 h-[2px] bg-[#121B24] transition-all duration-300"></span>
            <span class="block w-6 h-[2px] bg-[#121B24] transition-all duration-300"></span>
          </button>
        </div>
      </div>
    </nav>

    {/* Mobile nav drawer */}
    <div id="mobile-nav" class="hidden lg:hidden fixed inset-0 bg-white z-50 flex flex-col pt-20 px-8 gap-6">
      <button id="close-nav" class="absolute top-6 right-6 text-3xl leading-none text-[#121B24]" aria-label="Close">&times;</button>
      {navLinks.map((l) => (
        <a href={l.href} class="text-[#121B24] font-[Josefin_Sans] font-extrabold text-lg uppercase tracking-widest">{l.label}</a>
      ))}
      <a href="tel:6023131488" class="text-[#1B2A54] font-[Josefin_Sans] font-extrabold text-lg uppercase tracking-widest">(602) 313-1488</a>
      <a href="#" class="btn btn-primary self-start">Schedule Now</a>
    </div>

    {/* ============================================
        HERO
        ============================================ */}
    <section class="relative">
      <div class="relative min-h-[720px] flex items-center" style="background-image: linear-gradient(rgba(18,27,36,0.55), rgba(18,27,36,0.75)), url('/images/peak-lobby.jpg'); background-size: cover; background-position: center;">
        <div class="max-w-[1280px] mx-auto px-6 py-[120px] w-full">
          <div class="max-w-[780px]">
            <p class="eyebrow mb-4">Wellness Center in Scottsdale, AZ</p>
            <h1 class="font-[Josefin_Sans] font-black text-white uppercase text-[44px] md:text-[58px] leading-[1.04] tracking-[0.5px] mb-6">
              Unlock Your Peak<br/>Potential
            </h1>
            <p class="text-white/90 text-[18px] md:text-[20px] font-light leading-[1.7] mb-8 max-w-[640px]">
              Look better, feel better, and live more fully with advanced treatments of our medical spa & wellness center in Scottsdale that blend science and nature to truly transform your health and vitality.
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="#treatments" class="btn btn-primary">Popular Services</a>
              <a href="#" class="btn btn-outline-light">Book Now</a>
            </div>
          </div>
        </div>
      </div>
      {/* Benefits strip */}
      <div class="bg-[#1B2A54] text-white">
        <div class="max-w-[1440px] mx-auto px-6">
          <ul class="flex flex-wrap lg:flex-nowrap justify-between divide-x divide-white/15">
            {heroBenefits.map((b) => (
              <li class="flex-1 min-w-[50%] lg:min-w-0 text-center py-5 px-4 font-[Josefin_Sans] font-extrabold text-[13px] md:text-[14px] tracking-[1.5px] uppercase">
                {b}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* ============================================
        ABOUT / YOUR JOURNEY
        ============================================ */}
    <section class="py-[120px] bg-white">
      <div class="max-w-[1280px] mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative reveal">
          <img src="/images/peak-lobby-4.jpg" alt="Peak Wellness lobby" class="w-full h-auto shadow-2xl" />
          <img src="/images/about-biohacking.jpg" alt="Biohacking" class="hidden md:block absolute -bottom-12 -right-8 w-[55%] shadow-2xl border-[8px] border-white" />
        </div>
        <div class="reveal">
          <p class="eyebrow mb-4">Scottsdale's Premier Wellness Spa</p>
          <h2 class="h2-display mb-6">Your Journey to Peak Wellness Begins Here</h2>
          <p class="body-lg mb-8">
            What if you could defy aging and amplify your vitality? Imagine how much more fulfilling life would feel if the pain was gone, you moved more freely, had your dream body, and woke up everyday looking and feeling amazing? At The Peak, it's possible. Combining decades of holistic and medical experience with the world's most innovative and effective equipment, we'll help you live a healthier, more vibrant life.
          </p>
          <a href="#" class="btn btn-primary">About The Peak</a>
        </div>
      </div>
    </section>

    {/* ============================================
        BRAND LOGO MARQUEE
        ============================================ */}
    <section class="py-[60px] bg-[#F6F2E9] border-y border-[#E5E0D6] overflow-hidden marquee-wrap">
      <div class="marquee-track">
        {[...brandLogos, ...brandLogos].map((b) => (
          <div class="flex-shrink-0 w-[200px] mx-[35px] flex items-center justify-center">
            <img src={b.src} alt={b.alt} class="max-h-[80px] w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-80 hover:opacity-100" loading="lazy" />
          </div>
        ))}
      </div>
    </section>

    {/* ============================================
        POPULAR TREATMENTS SWIPER
        ============================================ */}
    <section id="treatments" class="py-[120px] bg-[#121B24] text-white">
      <div class="max-w-[1440px] mx-auto px-6">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">Popular</p>
          <h2 class="h2-display text-white">Popular Treatments</h2>
        </div>
        <div class="swiper treatments-swiper">
          <div class="swiper-wrapper">
            {[...treatments, ...treatments].map((t) => (
              <div class="swiper-slide">
                <div class="treatment-card bg-[#1B2A54] flex flex-col h-full">
                  <div class="aspect-[4/5] overflow-hidden">
                    <img src={t.img} alt={t.title} class="w-full h-full object-cover" />
                  </div>
                  <div class="p-6 flex flex-col gap-3 flex-1">
                    <span class="text-[11px] font-[Figtree] font-semibold tracking-[2px] uppercase text-[#D7A67B]">{t.category}</span>
                    <h3 class="font-[Josefin_Sans] font-black text-[24px] uppercase leading-[1.1] text-white">{t.title}</h3>
                    <div class="mt-auto pt-2">
                      <a href={t.href} class="btn btn-outline-light text-[12px] w-full">Learn More</a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {/* ============================================
        WHY CHOOSE US / PEAK DIFFERENCE
        ============================================ */}
    <section class="py-[120px] bg-white">
      <div class="max-w-[1280px] mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="eyebrow mb-3">Why Choose Us</p>
          <h2 class="h2-display mb-10">The Peak Difference: Wellness Reimagined</h2>
          <ul class="flex flex-col gap-6">
            {peakFeatures.map((f, i) => (
              <li class="flex items-start gap-5">
                <div class="w-[56px] h-[56px] bg-[#F6F2E9] border border-[#E5E0D6] flex items-center justify-center text-[#1B2A54] flex-shrink-0" set:html={featureIcons[i]}></div>
                <div>
                  <h3 class="font-[Josefin_Sans] font-extrabold text-[18px] md:text-[20px] tracking-[1px] uppercase text-[#121B24] mb-1">{f.title}</h3>
                  <p class="text-[15px] text-[#5E5E5E] font-light leading-[1.7]">{f.desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <div class="mt-10">
            <a href="#" class="btn btn-primary">Schedule Now</a>
          </div>
        </div>
        <div>
          <img src="/images/wellness-treatment.webp" alt="Peak Wellness treatment" class="w-full h-auto shadow-2xl" />
        </div>
      </div>
    </section>

    {/* ============================================
        MEMBERSHIP BANNER (mountain top + navy bg)
        ============================================ */}
    <section class="relative mt-16">
      <div class="mountain-top py-[120px]" style="background-image: linear-gradient(rgba(27,42,84,0.85), rgba(27,42,84,0.9)), url('/images/bg-blue-marble.jpg'); background-size: cover; background-position: center;">
        <div class="max-w-[1280px] mx-auto px-6 flex flex-col lg:flex-row items-center justify-between gap-8 pt-10">
          <h3 class="font-[Josefin_Sans] font-extrabold text-white uppercase text-[28px] md:text-[36px] leading-[1.15] tracking-[0.5px] text-center lg:text-left max-w-[780px]">
            Elevate your health for less with a Peak Membership!
          </h3>
          <a href="#" class="btn btn-outline-light">View Memberships</a>
        </div>
      </div>
    </section>

    {/* ============================================
        BEFORE & AFTER SWIPER
        ============================================ */}
    <section class="py-[120px] bg-white">
      <div class="max-w-[1440px] mx-auto px-6">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">Real People. Real Results.</p>
          <h2 class="h2-display mb-4">Real People. Real Results.</h2>
          <p class="body-lg max-w-[640px] mx-auto">Before and after results that speak for themselves.</p>
        </div>
        <div class="relative">
          <div class="swiper before-after-swiper">
            <div class="swiper-wrapper">
              {[...beforeAfter, ...beforeAfter].map((ba) => (
                <div class="swiper-slide">
                  <figure class="flex flex-col">
                    <div class="aspect-square overflow-hidden">
                      <img src={ba.img} alt={ba.label} class="w-full h-full object-cover" />
                    </div>
                    <figcaption class="bg-[#1B2A54] text-white text-center py-3 font-[Josefin_Sans] font-extrabold text-[13px] tracking-[1.5px] uppercase">
                      {ba.label}
                    </figcaption>
                  </figure>
                </div>
              ))}
            </div>
          </div>
          <div class="ba-prev swiper-button-prev"></div>
          <div class="ba-next swiper-button-next"></div>
        </div>
      </div>
    </section>

    {/* ============================================
        CHERRY FINANCING
        ============================================ */}
    <section class="bg-[#F6F2E9]">
      <div class="grid lg:grid-cols-2">
        <div class="min-h-[500px] bg-cover bg-center" style="background-image: url('/images/pretty-woman-beach.jpg');"></div>
        <div class="py-[100px] px-8 md:px-16 flex flex-col justify-center">
          <h2 class="h2-display mb-6">Treat Yourself Today, Pay Later — You're Worth It.</h2>
          <p class="body-lg mb-8">
            When we don't feel good about ourselves, everything else suffers. You don't have to put off feeling your best any longer! Cherry makes it easy to look and feel great now.
          </p>
          <ul class="check-list mb-10">
            {financingBullets.map((b) => <li>{b}</li>)}
          </ul>
          <div>
            <a href="#" class="btn btn-primary">Apply Now</a>
          </div>
        </div>
      </div>
    </section>

    {/* ============================================
        HERO TESTIMONIAL
        ============================================ */}
    <section class="py-[120px] bg-white">
      <div class="max-w-[960px] mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-1 mb-6">
          {[...Array(5)].map(() => (
            <svg class="w-6 h-6 star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 4.84 5.34.78-3.86 3.77.91 5.32L12 14.27 7.22 16.71l.91-5.32L4.27 7.62l5.34-.78z"/></svg>
          ))}
        </div>
        <blockquote class="font-[Josefin_Sans] font-extrabold text-[28px] md:text-[42px] leading-[1.2] uppercase text-[#121B24] mb-8">
          "This is the most amazing one-stop wellness center I've ever experienced."
        </blockquote>
        <p class="font-[Josefin_Sans] font-extrabold tracking-[2px] text-[#1B2A54] mb-2">— Bucket List Bliss</p>
        <p class="text-[#D7A67B] font-[Figtree] font-semibold tracking-[2px] text-[13px] uppercase">5.0 Rating Based on 100+ Reviews</p>
      </div>
    </section>

    {/* ============================================
        GIFT CARD (navy marble)
        ============================================ */}
    <section class="py-[100px]" style="background-image: linear-gradient(rgba(18,27,36,0.85), rgba(27,42,84,0.9)), url('/images/bg-blue-marble.jpg'); background-size: cover; background-position: center;">
      <div class="max-w-[1200px] mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <img src="/images/peak-gift-card.jpg" alt="Peak Gift Card" class="w-full max-w-[520px] shadow-2xl" />
        </div>
        <div>
          <p class="eyebrow mb-3">Wellness =</p>
          <h2 class="font-[Josefin_Sans] font-black text-white uppercase text-[40px] md:text-[56px] leading-[1.05] mb-6">The Best Gift Ever</h2>
          <p class="text-white/85 text-[18px] font-light leading-[1.8] mb-8">
            Give the gift of vitality and wellness. Peak gift cards are redeemable on any service — from red light therapy to Emsculpt Neo to a full wellness plan.
          </p>
          <a href="#" class="btn btn-white">Buy a Peak Gift Card</a>
        </div>
      </div>
    </section>

    {/* ============================================
        TESTIMONIALS SWIPER
        ============================================ */}
    <section class="py-[120px] bg-[#F6F2E9]">
      <div class="max-w-[1440px] mx-auto px-6">
        <div class="text-center mb-12">
          <p class="eyebrow mb-3">Real Reviews</p>
          <h2 class="h2-display">What Our Patients Are Saying</h2>
        </div>
        <div class="swiper testimonials-swiper">
          <div class="swiper-wrapper">
            {testimonials.map((t) => (
              <div class="swiper-slide">
                <article class="bg-white p-8 md:p-10 h-full flex flex-col gap-5 shadow-md">
                  <div class="flex items-center gap-1">
                    {[...Array(5)].map(() => (
                      <svg class="w-5 h-5 star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 4.84 5.34.78-3.86 3.77.91 5.32L12 14.27 7.22 16.71l.91-5.32L4.27 7.62l5.34-.78z"/></svg>
                    ))}
                  </div>
